---
import Layout from '../layouts/Layout.astro';
import Home from '../components/Home.jsx';
import { sanityClient } from '../sanity/client';

// Attempt to fetch homepage settings from Sanity (with a safe fallback if credentials aren't set yet)
let sanityData = null;
try {
  sanityData = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
  console.log("SANITY DATA FETCHED:", JSON.stringify(sanityData, null, 2));
} catch (error) {
  console.warn("Sanity fetch failed:", error);
}

const title = sanityData?.title || "HTL Aircon";
---

<Layout title={title}>
  <Home client:load sanityData={sanityData} />
</Layout>
